rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.active == true;
    }

    function signedInWithVerifiedEmail() {
      return signedIn()
        && request.auth.token.email != null
        && request.auth.token.email_verified == true;
    }

    function emailMatchesApproval(emailKey) {
      return exists(/databases/$(database)/documents/adminEmails/$(emailKey))
        && get(/databases/$(database)/documents/adminEmails/$(emailKey)).data.email == request.auth.token.email;
    }

    function hasActiveInvite(emailKey) {
      return emailMatchesApproval(emailKey)
        && get(/databases/$(database)/documents/adminEmails/$(emailKey)).data.active == true
        && get(/databases/$(database)/documents/adminEmails/$(emailKey)).data.inviteUsedAt == null
        && get(/databases/$(database)/documents/adminEmails/$(emailKey)).data.inviteToken == request.resource.data.inviteToken
        && get(/databases/$(database)/documents/adminEmails/$(emailKey)).data.inviteExpiresAt > request.time;
    }

    match /site/announcements {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /contactRequests/{requestId} {
      allow create: if request.resource.data.keys().hasOnly([
          "name",
          "contact",
          "message",
          "consent",
          "status",
          "page",
          "createdAt"
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 1
        && request.resource.data.name.size() <= 80
        && request.resource.data.contact is string
        && request.resource.data.contact.size() >= 1
        && request.resource.data.contact.size() <= 120
        && request.resource.data.message is string
        && request.resource.data.message.size() >= 1
        && request.resource.data.message.size() <= 1000
        && request.resource.data.consent == true
        && request.resource.data.status == "new"
        && request.resource.data.page == "home"
        && request.resource.data.createdAt == request.time;
      allow read, update, delete: if isAdmin();
    }

    match /admins/{uid} {
      allow get: if isAdmin() || (signedIn() && request.auth.uid == uid);
      allow list: if isAdmin();
      allow create: if request.auth.uid == uid
        && signedIn()
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.active == true
        && request.resource.data.role == "admin"
        && request.resource.data.emailKey is string
        && request.resource.data.inviteToken is string
        && hasActiveInvite(request.resource.data.emailKey);
      allow update, delete: if isAdmin();
    }

    match /adminEmails/{emailKey} {
      allow get: if isAdmin()
        || (signedInWithVerifiedEmail() && resource.data.email == request.auth.token.email);
      allow list, create, update, delete: if isAdmin();
    }
  }
}
